# ---------------------------------------------------------------------------
# Template only. Copy to `.env` and replace every placeholder before booting.
# Never commit a populated `.env` — the file is gitignored for a reason.
# SECRET_KEY, DATABASE_URL, CORS_ORIGINS, FRONTEND_URL and TOTP_ENCRYPTION_KEY
# are ALL required; the backend refuses to start if any is missing or left at
# its placeholder (see the field validators in backend/app/config.py, e.g.
# reject_weak_database_url for the DATABASE_URL 'changeme' poison value and the
# verify_key_configured() startup check for TOTP_ENCRYPTION_KEY).
#
# docker-compose.prod.yml reads individual variables from the host environment
# (or a .env file loaded by `docker compose --env-file`) rather than mounting
# the whole .env into the backend container. POSTGRES_PASSWORD therefore never
# appears in the backend's process environment — only in the postgres service.
# ---------------------------------------------------------------------------

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 chars of entropy. Do NOT reuse across environments.
SECRET_KEY=CHANGE_ME_RUN_THE_COMMAND_ABOVE

# Use service name "postgres" when running via docker compose; "localhost" when
# running the backend outside Docker against a local PG instance.
# The literal `:changeme@` below is a deliberate poison value — the backend's
# reject_weak_database_url validator refuses to start while it's present, so a
# forgotten copy-paste fails loudly instead of booting with a weak password.
# Generate a real one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
DATABASE_URL=postgresql+psycopg://mathdefense:changeme@postgres:5432/math_defense
POSTGRES_PASSWORD=changeme
# M-13: Least-privilege app role. Used by pg_init_roles.sh on first DB init to
# create the DML-only `mathdefense_app` role.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_APP_PASSWORD=changeme
# Optional (M-13): route RUNTIME queries through the least-privilege app role.
# When set, app/db/database.py connects with this URL while Alembic keeps using
# the admin DATABASE_URL above for migrations (DDL). Leave it unset/blank to run
# everything through the admin role. The password must equal POSTGRES_APP_PASSWORD.
# DATABASE_URL_APP=postgresql+psycopg://mathdefense_app:<POSTGRES_APP_PASSWORD>@postgres:5432/math_defense
# Comma-separated browser origins allowed to call the API. Required.
# Dev:  CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Prod: CORS_ORIGINS=https://your.domain
#
# NOTE — nginx CORS allow-list uses a separate pair of variables (CORS_ORIGIN_1,
# CORS_ORIGIN_2) that are substituted into nginx.conf / nginx-tls.conf at
# container start by envsubst (see docker-compose.prod.yml). These two sets
# MUST be kept in sync manually: CORS_ORIGINS drives the FastAPI CORS middleware
# while CORS_ORIGIN_{1,2} drive the nginx map block for preflight handling.
# nginx is therefore hard-capped at two origins; to allow a third, extend the
# map block and add a CORS_ORIGIN_3 slot in docker-compose.prod.yml.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Reverse-proxy trust (C-02). Set PROXY_MODE=true when the backend runs behind
# nginx (or any proxy) so per-IP rate limits key on the real client address
# from X-Forwarded-For rather than the proxy's internal IP. TRUSTED_PROXY_IPS
# is a comma-separated list of IPs or CIDR blocks whose X-Forwarded-For header
# the backend will trust. Use the Docker Compose network subnet (172.16.0.0/12
# covers the default Docker RFC-1918 range) or the exact nginx container IP.
# Leave blank for direct-to-internet deployments without a proxy.
PROXY_MODE=false
TRUSTED_PROXY_IPS=
# Base URL used in outbound emails (e.g., verification links). Required.
# Dev:  FRONTEND_URL=http://localhost:5173
# Prod: FRONTEND_URL=https://your.domain
FRONTEND_URL=http://localhost:5173
# AES-256 Fernet key encrypting TOTP secrets at rest. REQUIRED at startup —
# the lifespan handler calls verify_key_configured() before serving the
# first request, so a missing or malformed value aborts boot regardless of
# whether MFA is actually used.
# Generate with:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOTP_ENCRYPTION_KEY=
# Set to "true" to seed the dev teacher + student + admin accounts on startup
# (see backend/app/seed.py and frontend/src/views/AuthView.vue — both
# files carry the same hardcoded credential list, surfaced as click-to-fill
# buttons on the login page):
#   teacher@mathdefense.local / TeacherDev2026!
#   student@mathdefense.local / StudentDev2026!
#   admin@mathdefense.local   / AdminDev2026!
# Defaults to disabled when unset. A localhost-only guard in seed.py refuses
# to run unless FRONTEND_URL points at a recognised local-dev host, so flipping
# this on in production is still a no-op.
SEED_DEMO_USER=false
# Bootstrap admin account — THE supported way to set the production admin login.
# Set EMAIL + PASSWORD here and the first admin is seeded on initial boot.
# Wired through both docker-compose.yml (dev) and docker-compose.prod.yml (prod),
# so these values reach the backend in either environment. Omitting either is a no-op.
#
# Create-once semantics (idempotent): if the email already exists the row is
# left untouched — a password the admin later changes in-app (Profile → change
# password) is preserved, and re-seeding never overwrites it. To rotate: change
# it in-app as that admin, or delete the DB row and reboot. You may blank
# SEED_ADMIN_PASSWORD after first boot.
#
# WARNING: when SEED_DEMO_USER=true (local dev only), do NOT set SEED_ADMIN_EMAIL
# to a dev-account email (e.g. admin@mathdefense.local). This bootstrap seed runs
# first and would create that email with THIS password, shadowing the dev seed so
# the login page's "Admin" button (which fills AdminDev2026!) can no longer sign
# in. In production SEED_DEMO_USER is off, so just use your real admin email here.
# Generate a strong password with:
#   python -c "import secrets; print(secrets.token_urlsafe(24))"
SEED_ADMIN_EMAIL=
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
