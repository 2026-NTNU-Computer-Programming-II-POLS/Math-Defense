# ---------------------------------------------------------------------------
# Template only. Copy to `.env` and replace every placeholder before booting.
# Never commit a populated `.env` — the file is gitignored for a reason.
# Both values below are REQUIRED; backend will refuse to start if either is
# left at its placeholder (see reject_default_password validator in
# backend/app/config.py).
#
# docker-compose.prod.yml reads individual variables from the host environment
# (or a .env file loaded by `docker compose --env-file`) rather than mounting
# the whole .env into the backend container. POSTGRES_PASSWORD therefore never
# appears in the backend's process environment — only in the postgres service.
# ---------------------------------------------------------------------------

# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
# Must be at least 32 chars of entropy. Do NOT reuse across environments.
SECRET_KEY=CHANGE_ME_RUN_THE_COMMAND_ABOVE

# Use service name "postgres" when running via docker compose; "localhost" when
# running the backend outside Docker against a local PG instance.
# The literal `:changeme@` below is a deliberate poison value — the backend's
# reject_default_password validator refuses to start while it's present, so a
# forgotten copy-paste fails loudly instead of booting with a weak password.
# Generate a real one with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
DATABASE_URL=postgresql+psycopg://mathdefense:changeme@postgres:5432/math_defense
POSTGRES_PASSWORD=changeme
# M-13: Least-privilege app role. Used by pg_init_roles.sh on first DB init.
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(32))"
# The runtime DATABASE_URL above uses the admin role (DDL for Alembic). If you
# want least-privilege at runtime, set a second DATABASE_URL_APP pointing at
# this role:  postgresql+psycopg://mathdefense_app:<this>@postgres:5432/math_defense
POSTGRES_APP_PASSWORD=changeme
# Comma-separated browser origins allowed to call the API. Required.
# Dev:  CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Prod: CORS_ORIGINS=https://your.domain
#
# NOTE — nginx CORS allow-list uses a separate pair of variables (CORS_ORIGIN_1,
# CORS_ORIGIN_2) that are substituted into nginx.conf / nginx-tls.conf at
# container start by envsubst (see docker-compose.prod.yml). These two sets
# MUST be kept in sync manually: CORS_ORIGINS drives the FastAPI CORS middleware
# while CORS_ORIGIN_{1,2} drive the nginx map block for preflight handling.
# nginx is therefore hard-capped at two origins; to allow a third, extend the
# map block and add a CORS_ORIGIN_3 slot in docker-compose.prod.yml.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# Reverse-proxy trust (C-02). Set PROXY_MODE=true when the backend runs behind
# nginx (or any proxy) so per-IP rate limits key on the real client address
# from X-Forwarded-For rather than the proxy's internal IP. TRUSTED_PROXY_IPS
# is a comma-separated list of IPs or CIDR blocks whose X-Forwarded-For header
# the backend will trust. Use the Docker Compose network subnet (172.16.0.0/12
# covers the default Docker RFC-1918 range) or the exact nginx container IP.
# Leave blank for direct-to-internet deployments without a proxy.
PROXY_MODE=false
TRUSTED_PROXY_IPS=
# Base URL used in outbound emails (e.g., verification links). Required.
# Dev:  FRONTEND_URL=http://localhost:5173
# Prod: FRONTEND_URL=https://your.domain
FRONTEND_URL=http://localhost:5173
# Set to "true" to seed a demo user on startup (see backend/app/seed.py).
# Defaults to disabled when unset — safe to omit in production.
SEED_DEMO_USER=false
# Required when SEED_DEMO_USER=true. Must pass the same strength rules as
# normal registration (see backend/app/application/auth_service.py).
# Ignored (and the seed is skipped) when SEED_DEMO_USER is not "true".
DEMO_SEED_PASSWORD=
