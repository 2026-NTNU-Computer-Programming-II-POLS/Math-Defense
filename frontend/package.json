{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "cd ../wasm && make",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run arch-check && npm run event-registry-check && vitest run",
    "test:watch": "vitest",
    "arch-check": "tsx scripts/arch-check.ts",
    "event-registry-check": "tsx scripts/event-registry-check.ts",
    "lint-chinese-comments": "tsx scripts/lint-chinese-comments.ts",
    "lint-determinism": "tsx scripts/lint-determinism.ts",
    "no-raw-px": "tsx scripts/no-raw-px.ts",
    "verify-wasm": "tsx scripts/verify-wasm.ts",
    "bench": "vitest run --config dev/vitest.bench.config.ts",
    "ci": "npm run arch-check && npm run event-registry-check && npm run lint-chinese-comments && npm run lint-determinism && npm run no-raw-px && vitest run"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "pinia": "^3.0.4",
    "vue": "^3.5.34",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.10",
    "@vue/tsconfig": "^0.9.0",
    "happy-dom": "^20.9.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.6",
    "vue-tsc": "^3.3.0"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  }
}
