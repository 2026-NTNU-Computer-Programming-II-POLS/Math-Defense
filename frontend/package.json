{
  "name": "frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "cd ../wasm && make",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run arch-check && vitest run",
    "test:watch": "vitest",
    "arch-check": "tsx scripts/arch-check.ts",
    "validate-levels": "tsx --tsconfig ./tsconfig.app.json scripts/validate-levels.ts",
    "lint-chinese-comments": "tsx scripts/lint-chinese-comments.ts",
    "ci": "npm run arch-check && npm run validate-levels && npm run lint-chinese-comments && vitest run"
  },
  "dependencies": {
    "katex": "^0.16.45",
    "pinia": "^3.0.4",
    "vue": "^3.5.30",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "happy-dom": "^20.8.9",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.8",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  },
  "overrides": {
    "postcss": ">=8.5.10"
  }
}
